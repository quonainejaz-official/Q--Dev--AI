<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Q-Dev-AI Chatbot</title>
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="stylesheet" href="/css/styles.css" />
  </head>
  <body>
    <div class="app-container">
      <div id="sidebarOverlay" class="sidebar-overlay"></div>
      <aside class="sidebar">
        <div class="sidebar-header">
          <div id="sidebarLogo" class="brand"></div>
          <button class="sidebar-toggle">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <rect x="3" y="3" width="18" height="18" rx="2" ry="2"></rect>
              <line x1="9" y1="3" x2="9" y2="21"></line>
            </svg>
          </button>
        </div>
        
        <button id="newChatButton" class="new-chat-btn">
          <span class="plus-icon">+</span>
          <span>New chat</span>
        </button>

        <div class="history-container">
          <div class="history-section">
            <p class="history-label">Today</p>
            <div id="chatHistory" class="history-list"></div>
          </div>
        </div>
      </aside>

      <main class="main-content">
        <div class="main-header">
          <button class="sidebar-toggle-main">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <rect x="3" y="3" width="18" height="18" rx="2" ry="2"></rect>
              <line x1="9" y1="3" x2="9" y2="21"></line>
            </svg>
          </button>
          <button id="newChatButtonMain" class="new-chat-btn-main">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <line x1="12" y1="5" x2="12" y2="19"></line>
              <line x1="5" y1="12" x2="19" y2="12"></line>
            </svg>
          </button>
        </div>

        <div id="welcomeScreen" class="welcome-screen">
          <div id="welcomeLogo" class="welcome-logo"></div>
          <h1 class="welcome-title">How can I help you?</h1>
        </div>

        <div id="chatArea" class="chat-area hidden">
          <header class="chat-header">
            <div class="chat-title-container">
              <h2 id="currentChatTitle" class="chat-title">New Chat</h2>
              <button id="editChatTitleBtn" class="edit-title-btn">
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                  <path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"></path>
                  <path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z"></path>
                </svg>
              </button>
            </div>
            <div class="chat-header-actions">
              <button id="exportPdfBtn" type="button" class="header-action-btn" title="Export as PDF">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                  <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"></path>
                  <polyline points="14 2 14 8 20 8"></polyline>
                  <line x1="8" y1="13" x2="16" y2="13"></line>
                  <line x1="8" y1="17" x2="16" y2="17"></line>
                  <polyline points="10 9 9 9 8 9"></polyline>
                </svg>
              </button>
            </div>
          </header>
          <section id="messages" class="messages"></section>
          <div id="typingIndicator" class="typing hidden">
            <div class="typing-dot"></div>
            <div class="typing-dot"></div>
            <div class="typing-dot"></div>
          </div>
        </div>

        <div class="input-container">
          <form id="chatForm" class="composer" autocomplete="off">
            <div class="input-wrapper">
              <div id="imagePreviewBar" class="image-preview-bar hidden">
                <div id="previewImagesList" class="preview-images-list"></div>
              </div>
              <textarea
                id="messageInput"
                placeholder="Message"
                maxlength="50000"
                rows="1"
              ></textarea>
              <div id="recordingIndicator" class="recording-indicator hidden">
                <div class="recording-wave">
                  <span></span><span></span><span></span><span></span><span></span>
                </div>
                <span class="recording-text">Listening...</span>
                <span class="recording-tap-hint">Tap mic again to stop & send</span>
              </div>
              <div id="imageModeBanner" class="image-mode-banner hidden">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                  <rect x="3" y="3" width="18" height="18" rx="2" ry="2"></rect>
                  <circle cx="8.5" cy="8.5" r="1.5"></circle>
                  <polyline points="21 15 16 10 5 21"></polyline>
                </svg>
                <span>Image generation mode</span>
                <button id="exitImageModeBtn" type="button" class="exit-image-mode-btn">&times;</button>
              </div>
              <div class="input-footer">
                <div class="input-actions-left">
                  <div class="add-btn-wrapper">
                    <button id="addButton" type="button" class="add-btn" title="Add">
                      <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                        <line x1="12" y1="5" x2="12" y2="19"></line>
                        <line x1="5" y1="12" x2="19" y2="12"></line>
                      </svg>
                    </button>
                    <div id="addMenu" class="add-menu hidden">
                      <button class="add-menu-item" data-action="file">
                        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                          <path d="M21.44 11.05l-9.19 9.19a6 6 0 0 1-8.49-8.49l9.19-9.19a4 4 0 0 1 5.66 5.66l-9.2 9.19a2 2 0 0 1-2.83-2.83l8.49-8.48"></path>
                        </svg>
                        <span>Add photos & files</span>
                      </button>
                      <button class="add-menu-item" data-action="audio">
                        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                          <path d="M9 18V5l12-2v13"></path>
                          <circle cx="6" cy="18" r="3"></circle>
                          <circle cx="18" cy="16" r="3"></circle>
                        </svg>
                        <span>Upload audio</span>
                      </button>
                      <div class="add-menu-divider"></div>
                      <button class="add-menu-item" data-action="image-gen">
                        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                          <rect x="3" y="3" width="18" height="18" rx="2" ry="2"></rect>
                          <circle cx="8.5" cy="8.5" r="1.5"></circle>
                          <polyline points="21 15 16 10 5 21"></polyline>
                        </svg>
                        <span>Create image</span>
                      </button>
                    </div>
                  </div>
                </div>
                <div class="input-actions-right">
                  <button id="attachButton" type="button" class="attach-btn" title="Attach file">
                    <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                      <path d="M21.44 11.05l-9.19 9.19a6 6 0 0 1-8.49-8.49l9.19-9.19a4 4 0 0 1 5.66 5.66l-9.2 9.19a2 2 0 0 1-2.83-2.83l8.49-8.48"></path>
                    </svg>
                  </button>
                  <input type="file" id="fileInput" accept="image/*,audio/*,video/*,application/pdf" multiple hidden />
                  <input type="file" id="imageInput" accept="image/*" multiple hidden />
                  <button id="audioAttachButton" type="button" class="attach-btn" title="Attach audio">
                    <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                      <path d="M9 18V5l12-2v13"></path>
                      <circle cx="6" cy="18" r="3"></circle>
                      <circle cx="18" cy="16" r="3"></circle>
                    </svg>
                  </button>
                  <input type="file" id="audioInput" accept="audio/*" multiple hidden />
                  <button id="micButton" type="button" class="attach-btn mic-btn" title="Voice input">
                    <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                      <path d="M12 1a3 3 0 0 0-3 3v8a3 3 0 0 0 6 0V4a3 3 0 0 0-3-3z"></path>
                      <path d="M19 10v2a7 7 0 0 1-14 0v-2"></path>
                      <line x1="12" y1="19" x2="12" y2="23"></line>
                      <line x1="8" y1="23" x2="16" y2="23"></line>
                    </svg>
                  </button>
                  <button id="sendButton" type="submit" class="send-btn" disabled>
                    <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                      <line x1="12" y1="19" x2="12" y2="5"></line>
                      <polyline points="5 12 12 5 19 12"></polyline>
                    </svg>
                  </button>
                </div>
              </div>
            </div>
          </form>
          <p class="disclaimer">AI-generated, for reference only</p>
        </div>
      </main>
    </div>

    <div id="imageViewer" class="image-viewer-overlay hidden">
      <div class="image-viewer-content">
        <div class="image-viewer-header">
          <h3 id="imageViewerTitle">Generated Image</h3>
          <div class="image-viewer-actions">
            <button id="imageViewerCopy" class="image-viewer-action-btn" title="Copy SVG">Copy</button>
            <button id="imageViewerDownload" class="image-viewer-action-btn" title="Download">Download</button>
            <button id="imageViewerEdit" class="image-viewer-action-btn" title="Edit">Edit</button>
            <button id="imageViewerClose" class="image-viewer-close-btn" title="Close">&times;</button>
          </div>
        </div>
        <div class="image-viewer-body">
          <img id="imageViewerImg" src="" alt="Generated image" />
        </div>
        <div id="imageViewerEditPanel" class="image-viewer-edit-panel hidden">
          <input type="text" id="imageViewerEditInput" class="image-viewer-edit-input" placeholder="Edit prompt..." />
          <button id="imageViewerEditSubmit" class="image-viewer-edit-submit">Regenerate</button>
        </div>
      </div>
    </div>

    <div id="customModal" class="modal-overlay hidden">
      <div class="modal">
        <h3 id="modalTitle">Confirmation</h3>
        <p id="modalMessage">Are you sure you want to proceed?</p>
        <div class="modal-actions">
          <button id="modalCancel" class="btn-secondary">Cancel</button>
          <button id="modalConfirm" class="btn-primary">Confirm</button>
        </div>
      </div>
    </div>

    <div id="toastContainer" class="toast-container"></div>

    <script>
      window.__INITIAL_MESSAGES__ = <%- initialMessages %>;
    </script>
    <script src="/js/chat.js"></script>
  </body>
</html>